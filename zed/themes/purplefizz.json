{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "Purple Fizz",
  "author": "blud0t",
  "themes": [
    {
      "name": "Purple Fizz",
      "appearance": "dark",
      "style": {
        "background": "#15111C",
        "border": "#361A52",
        "border.variant": "#2A1342",
        "border.focused": "#A855F7",
        "elevated_surface.background": "#1A0B26",
        "surface.background": "#10051C",
        "title_bar.background": "#150824",
        "title_bar.inactive_background": "#0F051A",
        "status_bar.background": "#1E0C30",
        "panel.background": "#1A0B26",
        "element.background": "#1A1523",
        "element.hover": "#8B3DFF40",
        "element.active": "#8B3DFF",
        "element.selected": "#8B3DFF30",
        "ghost_element.hover": "#8B3DFF40",
        "ghost_element.active": "#8B3DFF",
        "ghost_element.selected": "#8B3DFF30",
        "text": "#f8f8f2",
        "text.muted": "#C5B4D6",
        "text.accent": "#A855F7",

        "tab.inactive_background": "#160921",
        "tab.active_background": "#15111C",
        "tab_bar.background": "#15081E",

        "editor.background": "#15111C",
        "editor.foreground": "#f8f8f2",
        "editor.gutter.background": "#15111C",
        "editor.invisible": "#352A45",
        "editor.line_number": "#352A45",
        "editor.active_line_number": "#FFFFFF",
        "editor.active_line.background": "#1E1828",
        "editor.document_highlight.read_background": "#A855F720",
        "editor.indent_guide": "#423556",
        "editor.indent_guide_active": "#A855F7",

        "terminal.background": "#15111C",
        "terminal.foreground": "#f8f8f2",

        "error": "#F44747",
        "error.background": "#F4474715",
        "error.border": "#F4474740",
        "warning": "#CD9731",
        "warning.background": "#CD973115",
        "warning.border": "#CD973140",
        "info": "#6796E6",
        "info.background": "#6796E615",
        "info.border": "#6796E640",
        "hint": "#A094B0",
        "hint.background": "#A094B015",
        "hint.border": "#A094B040",

        "players": [
          {
            "cursor": "#f8f8f0",
            "selection": "#8B3DFF40",
            "background": "#A855F730"
          }
        ],

        "syntax": {
          "comment": { "color": "#8C8C8C", "font_style": "italic" },
          "string": { "color": "#FFEE99" },
          "number": { "color": "#FF80F4" },
          "boolean": { "color": "#FF80F4" },
          "keyword": { "color": "#F92672" },
          "type": { "color": "#66D9EF", "font_style": "italic" },
          "constructor": { "color": "#A6E22E" },
          "function": { "color": "#A6E22E" },
          "method": { "color": "#A6E22E" },
          "variable": { "color": "#f8f8f2" },
          "variable.parameter": { "color": "#FD971F", "font_style": "italic" },
          "property": { "color": "#A6E22E" },
          "constant": { "color": "#FF80F4" },
          "tag": { "color": "#F92672" },
          "attribute": { "color": "#A6E22E" },
          "punctuation.special": { "color": "#F92672" },
          "link_text": { "color": "#A6E22E" },
          "link_uri": { "color": "#8C8C8C", "font_style": "italic" },
          "emphasis": { "color": "#F8F8F2", "font_style": "italic" },
          "strong": { "color": "#F8F8F2", "font_weight": 700 },
          "deleted": { "color": "#D3201F" },
          "inserted": { "color": "#60CF30" },
          "predictive": { "color": "#8C8C8C", "font_style": "italic" }
        }
      }
    }
  ]
}
